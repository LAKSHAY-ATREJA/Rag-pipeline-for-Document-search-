# ── Environment variables for RAG Document Q&A ───────────────────────────────
#
# Copy this file to .env and fill in your values.
# The application reads GROQ_API_KEY automatically; all other variables are
# optional and are provided here for reference.
#
#   cp .env.example .env
#

# Groq API key (required for LLM inference)
# Obtain a free key at https://console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HuggingFace token (optional)
# Required only if you switch to a gated model on the HuggingFace Hub.
# Obtain at https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Streamlit server settings (optional — override when deploying)
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0
